apiVersion: apps/v1
kind: Deployment
metadata:
  name: game-store
  labels:
    app: game-store
spec:
  replicas: 2
  selector:
    matchLabels:
      app: game-store
  template:
    metadata:
      labels:
        app: game-store
    spec:
      containers:
        - name: game-store
          image: ${image}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: game-store
spec:
  type: NodePort
  selector:
    app: game-store
  ports:
    - name: http
      port: 80
      targetPort: 80
      nodePort: ${app_port}
