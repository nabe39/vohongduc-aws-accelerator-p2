# Local .terraform directories
**/.terraform/*
.terraform.lock.hcl
*.lock.hcl
*.tfstate.backup

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc


# Private SSH keys
*.pem

# Dynamic Kubernetes config files
kubeconfig_*.yaml

# Local environment secret files
.env
*.env
alertmanager-local.yaml
